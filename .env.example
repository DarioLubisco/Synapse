# ============================================================
# Synapse - Plantilla de Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo como ".env" en la misma carpeta
#   2. Rellena los valores reales
#   3. NUNCA subas el .env al repositorio
# ============================================================

# --- Conexion SQL Server ---
# Local/Dev: usar IP directa o nombre de instancia
# Produccion (Docker en OMV): usar IP de ZeroTier del servidor Windows
DB_SERVER=10.147.18.192\efficacis3
DB_DATABASE=EnterpriseAdmin_AMC
DB_USERNAME=sa
DB_PASSWORD=TU_PASSWORD_AQUI

# --- Driver ODBC ---
# Windows local:    ODBC Driver 17 for SQL Server
# Docker (Linux):   ODBC Driver 18 for SQL Server
DRIVER=ODBC Driver 18 for SQL Server
